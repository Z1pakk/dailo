{
  "endOfLine": "lf",
  "singleQuote": true,
  "bracketSameLine": false,
  "useTabs": false,
  "overrides": [
    {
      "files": ["*.html"],
      "options": {
        "parser": "angular-attributes",
        "htmlWhitespaceSensitivity": "ignore"
      }
    }
  ],
  "plugins": ["prettier-plugin-angular"]
}
